---
import { formatearMonto } from '../lib/format';
import type { Balance } from '../lib/types';

interface Props {
	balance: Balance;
}

const { balance } = Astro.props;
const { diferencia_meman, pagado_meman, pagado_paya, total_gastado } = balance;

const aPaz = Math.round(diferencia_meman) === 0;
const pagaPaya = diferencia_meman > 0;
const monto = Math.abs(diferencia_meman);
---

<div class="tarjeta tarjeta-balance">
	<p class="etiqueta texto-muted">Balance del mes</p>

	{
		aPaz ? (
			<p class="frase">Están a paz y salvo ✓</p>
		) : (
			<>
				<p class="monto-grande">{formatearMonto(monto)}</p>
				<p class="frase">
					{pagaPaya ? 'Paya le debe a Meman' : 'Meman le debe a Paya'}
				</p>
			</>
		)
	}

	<div class="totales">
		<div>
			<span class="texto-muted">Meman pagó</span>
			<strong>{formatearMonto(pagado_meman)}</strong>
		</div>
		<div>
			<span class="texto-muted">Paya pagó</span>
			<strong>{formatearMonto(pagado_paya)}</strong>
		</div>
		<div>
			<span class="texto-muted">Total del mes</span>
			<strong>{formatearMonto(total_gastado)}</strong>
		</div>
	</div>
</div>

<style>
	.tarjeta-balance {
		text-align: center;
	}

	.etiqueta {
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: var(--espacio-2);
	}

	.monto-grande {
		font-size: 2.6rem;
		font-weight: 800;
		margin: 0;
		letter-spacing: -0.02em;
	}

	.frase {
		margin: 4px 0 var(--espacio-4);
		color: var(--color-text-muted);
		font-weight: 500;
	}

	.totales {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--espacio-2);
		border-top: 1px solid var(--color-border);
		padding-top: var(--espacio-3);
	}

	.totales div {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.totales span {
		font-size: 0.72rem;
	}

	.totales strong {
		font-size: 0.95rem;
	}
</style>
