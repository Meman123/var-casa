---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GastoCard from '../../components/GastoCard.astro';
import IconoCategoria from '../../components/IconoCategoria.astro';
import ErrorBanner from '../../components/ErrorBanner.astro';
import { crearClienteApi, ApiError } from '../../lib/api';
import { formatearMesReferencia, formatearMonto, formatearFechaCorta, capitalizar, mesSiguiente } from '../../lib/format';
import type { Balance, Gasto, Mes } from '../../lib/types';
import { env } from 'cloudflare:workers';

export const prerender = false;

const { mes: mesReferencia } = Astro.params as { mes: string };
let gastos: Gasto[] = [];
let balance: Balance | null = null;
let mesInfo: Mes | undefined;
let error: string | null = null;

if (!env.N8N_BASE_URL) {
	error = 'La app no esta configurada correctamente (falta N8N_BASE_URL).';
} else {
	try {
		const api = crearClienteApi(env.N8N_BASE_URL);
		const [gastosRes, balanceRes, mesesRes] = await Promise.all([
			api.obtenerGastos(mesReferencia),
			api.obtenerBalance(mesReferencia),
			api.obtenerMeses(),
		]);
		gastos = gastosRes;
		balance = balanceRes;
		mesInfo = mesesRes.find((m) => m.mes_referencia === mesReferencia);
	} catch (e) {
		error = e instanceof ApiError ? e.message : 'No se pudo cargar el detalle del mes.';
	}
}

const correspondeMeman = balance ? balance.pagado_meman - balance.diferencia_meman : 0;
const correspondePaya = balance ? balance.total_gastado - correspondeMeman : 0;

const grupos = new Map<string, { icono: string; color: string; gastos: Gasto[] }>();
for (const g of gastos) {
	const clave = g.categoria_nombre;
	if (!grupos.has(clave)) grupos.set(clave, { icono: g.icono, color: g.color, gastos: [] });
	grupos.get(clave)!.gastos.push(g);
}

const gastosCronologicos = [...gastos].sort((a, b) => (a.fecha < b.fecha ? 1 : -1));

const siguiente = mesSiguiente(mesReferencia);
const diferenciaAbs = balance ? Math.abs(Math.round(balance.diferencia_meman)) : 0;
const deQuien = balance && balance.diferencia_meman < 0 ? 'meman' : 'paya';
const aQuien = deQuien === 'meman' ? 'paya' : 'meman';
---

<BaseLayout titulo={capitalizar(formatearMesReferencia(mesReferencia))}>
	<div class="contenedor">
		<h1>{capitalizar(formatearMesReferencia(mesReferencia))}</h1>

		{error && <ErrorBanner mensaje={error} />}

		{
			mesInfo && (
				<p class="estado-mes texto-muted">
					{mesInfo.estado === 'cerrado'
						? `✓ Cerrado${mesInfo.fecha_cierre ? ' el ' + formatearFechaCorta(mesInfo.fecha_cierre) : ''}`
						: '● Mes abierto'}
				</p>
			)
		}

		<div class="cuerpo-mes">
		{
			balance && (
				<section class="tarjeta area-balance">
					<h2>Balance</h2>
					<div class="tabla-balance">
						<div />
						<span class="texto-muted">Pagó</span>
						<span class="texto-muted">Le correspondía</span>

						<span>Meman</span>
						<strong>{formatearMonto(balance.pagado_meman)}</strong>
						<strong>{formatearMonto(correspondeMeman)}</strong>

						<span>Paya</span>
						<strong>{formatearMonto(balance.pagado_paya)}</strong>
						<strong>{formatearMonto(correspondePaya)}</strong>
					</div>
					<p class="resultado-balance">
						{Math.round(balance.diferencia_meman) === 0
							? 'Están a paz y salvo.'
							: `${deQuien === 'meman' ? 'Meman' : 'Paya'} le debe ${formatearMonto(diferenciaAbs)} a ${aQuien === 'meman' ? 'Meman' : 'Paya'}.`}
					</p>
				</section>
			)
		}

		{
			gastos.length > 0 && (
				<section class="tarjeta area-gastos">
					<div class="tabs">
						<button type="button" class="tab activa" data-vista="categoria">Por categoría</button>
						<button type="button" class="tab" data-vista="cronologico">Cronológico</button>
					</div>

					<div id="vista-categoria">
						{Array.from(grupos.entries()).map(([nombre, grupo]) => (
							<div class="grupo-categoria">
								<div class="grupo-cabecera">
									<IconoCategoria icono={grupo.icono} color={grupo.color} tamano="chico" />
									<span>{nombre}</span>
									<span class="texto-muted">
										{formatearMonto(grupo.gastos.reduce((acc, g) => acc + g.monto, 0))}
									</span>
								</div>
								{grupo.gastos.map((g) => (
									<GastoCard gasto={g} />
								))}
							</div>
						))}
					</div>

					<div id="vista-cronologico" hidden>
						{gastosCronologicos.map((g) => (
							<GastoCard gasto={g} />
						))}
					</div>
				</section>
			)
		}

		{
			mesInfo?.estado === 'abierto' && balance && (
				<section class="tarjeta area-cierre">
					<h2>Cerrar mes</h2>

					{Math.round(balance.diferencia_meman) !== 0 && (
						<div id="bloque-pago">
							<p class="texto-muted">
								{deQuien === 'meman' ? 'Meman' : 'Paya'} le debe {formatearMonto(diferenciaAbs)} a{' '}
								{aQuien === 'meman' ? 'Meman' : 'Paya'}. Puedes registrar el pago antes de cerrar.
							</p>
							<form id="form-pago">
								<input type="hidden" name="de_quien" value={deQuien} />
								<input type="hidden" name="a_quien" value={aQuien} />
								<div class="campo">
									<label for="monto_pago">Monto pagado</label>
									<input id="monto_pago" name="monto" type="number" min="1" value={diferenciaAbs} />
								</div>
								<button type="submit" class="boton boton-secundario">Registrar pago</button>
							</form>
						</div>
					)}

					<button id="boton-cerrar-mes" type="button" class="boton boton-primario" style="margin-top: var(--espacio-3); width: 100%;">
						Cerrar {formatearMesReferencia(mesReferencia)}
					</button>
					<p id="mensaje-error-cierre" class="mensaje-error" hidden></p>
				</section>
			)
		}
		</div>
	</div>

	<div id="overlay-celebracion" class="overlay-celebracion" hidden>
		<div class="check-circulo">✓</div>
		<p>¡Mes cerrado!</p>
	</div>
</BaseLayout>

<script is:inline define:vars={{ mesReferencia, siguienteAnio: siguiente.anio, siguienteMes: siguiente.mes, siguienteMesReferencia: siguiente.mesReferencia }}>
	document.querySelectorAll('.tab').forEach((tab) => {
		tab.addEventListener('click', () => {
			document.querySelectorAll('.tab').forEach((t) => t.classList.remove('activa'));
			tab.classList.add('activa');
			const vista = tab.dataset.vista;
			document.getElementById('vista-categoria').hidden = vista !== 'categoria';
			document.getElementById('vista-cronologico').hidden = vista !== 'cronologico';
		});
	});

	const formPago = document.getElementById('form-pago');
	formPago?.addEventListener('submit', async (evento) => {
		evento.preventDefault();
		const boton = formPago.querySelector('button');
		boton.disabled = true;
		const datos = new FormData(formPago);
		try {
			const respuesta = await fetch('/api/pagos-saldo', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					mes_referencia: mesReferencia,
					de_quien: datos.get('de_quien'),
					a_quien: datos.get('a_quien'),
					monto: Number(datos.get('monto')),
				}),
			});
			if (!respuesta.ok) {
				const json = await respuesta.json().catch(() => ({}));
				throw new Error(json.error ?? 'No se pudo registrar el pago.');
			}
			window.location.reload();
		} catch (error) {
			alert(error instanceof Error ? error.message : 'Error inesperado.');
			boton.disabled = false;
		}
	});

	const botonCerrar = document.getElementById('boton-cerrar-mes');
	const mensajeErrorCierre = document.getElementById('mensaje-error-cierre');
	botonCerrar?.addEventListener('click', async () => {
		if (!confirm('¿Cerrar este mes? No podrás registrar más gastos en él.')) return;
		botonCerrar.disabled = true;
		mensajeErrorCierre.hidden = true;
		try {
			const respuesta = await fetch('/api/meses/cerrar', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					mes_referencia: mesReferencia,
					siguiente_anio: siguienteAnio,
					siguiente_mes: siguienteMes,
					siguiente_mes_referencia: siguienteMesReferencia,
				}),
			});
			const json = await respuesta.json().catch(() => ({}));
			if (!respuesta.ok || !json.cerrado) {
				throw new Error(json.error ?? 'No se pudo cerrar el mes.');
			}

			const overlay = document.getElementById('overlay-celebracion');
			overlay.hidden = false;
			setTimeout(() => {
				window.location.href = '/historico';
			}, 1400);
		} catch (error) {
			mensajeErrorCierre.textContent = error instanceof Error ? error.message : 'Error inesperado.';
			mensajeErrorCierre.hidden = false;
			botonCerrar.disabled = false;
		}
	});
</script>

<style>
	.estado-mes {
		margin-top: -8px;
		margin-bottom: var(--espacio-4);
	}

	/* Mobile: apilado. Desktop: balance y cierre a la izquierda, gastos a la derecha. */
	.cuerpo-mes {
		display: grid;
		gap: var(--espacio-4);
		grid-template-areas:
			'balance'
			'gastos'
			'cierre';
	}

	.area-balance {
		grid-area: balance;
	}

	.area-gastos {
		grid-area: gastos;
	}

	.area-cierre {
		grid-area: cierre;
	}

	@media (min-width: 900px) {
		.cuerpo-mes {
			grid-template-columns: 5fr 6fr;
			gap: var(--espacio-5);
			grid-template-areas:
				'balance gastos'
				'cierre gastos'
				'. gastos';
			grid-template-rows: auto auto 1fr;
		}
	}

	.tabla-balance {
		display: grid;
		grid-template-columns: auto 1fr 1fr;
		gap: var(--espacio-2) var(--espacio-3);
		align-items: center;
		font-size: 0.9rem;
		margin-bottom: var(--espacio-3);
	}

	.resultado-balance {
		margin: 0;
		font-weight: 600;
		border-top: 1px solid var(--color-border);
		padding-top: var(--espacio-3);
	}

	.tabs {
		display: flex;
		gap: var(--espacio-2);
		margin-bottom: var(--espacio-3);
	}

	.tab {
		background: var(--color-bg-elevated-2);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		padding: 6px 14px;
		font-size: 0.8rem;
		color: var(--color-text-muted);
	}

	.tab.activa {
		background: var(--color-accent);
		color: var(--color-text-on-accent);
		border-color: transparent;
	}

	.grupo-categoria {
		margin-bottom: var(--espacio-4);
	}

	.grupo-cabecera {
		display: flex;
		align-items: center;
		gap: var(--espacio-2);
		font-weight: 700;
		font-size: 0.85rem;
		margin-bottom: var(--espacio-1);
	}

	.grupo-cabecera span:nth-child(2) {
		flex: 1;
	}

	#form-pago .campo {
		display: flex;
		flex-direction: column;
		gap: 6px;
		margin: var(--espacio-2) 0;
	}

	#form-pago input {
		background: var(--color-bg-elevated-2);
		border: 1px solid var(--color-border);
		border-radius: var(--radio-chico);
		padding: 10px 12px;
	}

	.mensaje-error {
		color: var(--color-danger);
		font-size: 0.85rem;
	}

	.overlay-celebracion {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.55);
		animation: fundido 0.25s ease;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: var(--espacio-3);
		z-index: 50;
		color: #fff;
		font-weight: 700;
		font-size: 1.1rem;
	}

	.check-circulo {
		width: 80px;
		height: 80px;
		border-radius: 999px;
		background: var(--color-accent);
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2.2rem;
		animation: aparecer 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	@keyframes aparecer {
		from {
			transform: scale(0);
			opacity: 0;
		}
		to {
			transform: scale(1);
			opacity: 1;
		}
	}

	@keyframes fundido {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.overlay-celebracion,
		.check-circulo {
			animation: none;
		}
	}
</style>
