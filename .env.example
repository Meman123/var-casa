# URL base de los webhooks de n8n (sin slash final), ej: https://n8n.tudominio.com/webhook
N8N_BASE_URL=https://n8n.yieldworks.com.co/webhook

# Secreto usado para firmar la cookie de sesion httpOnly. Cualquier string largo y aleatorio.
# Generar uno nuevo con: openssl rand -hex 32
SESSION_SECRET=icarly.com
